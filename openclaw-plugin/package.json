{
  "name": "@veriswarm/openclaw-plugin",
  "version": "0.1.0",
  "description": "VeriSwarm Guard plugin for OpenClaw — PII tokenization, trust scoring, policy enforcement, and audit for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp src/secret_rules_manifest.json dist/secret_rules_manifest.json",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "veriswarm",
    "guard",
    "pii",
    "trust",
    "security",
    "ai-agent"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2"
  }
}
