{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriswarm.ai/schemas/agent_profile.schema.json",
  "title": "AgentProfile",
  "type": "object",
  "required": ["slug", "display_name"],
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$|^[a-z0-9]$",
      "description": "URL-safe slug. Used in public badge URLs (/v1/badge/{slug}.svg) so the pattern enforces lowercase + digits + hyphens only."
    },
    "display_name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "maxLength": 2000 },
    "owner_name": { "type": "string", "maxLength": 200 },
    "owner_type": {
      "type": "string",
      "enum": ["individual", "organization", "unknown"]
    },
    "sponsor_domain": { "type": "string", "maxLength": 253 },
    "public_key": { "type": "string", "maxLength": 4096 },
    "runtime_name": { "type": "string", "maxLength": 128 },
    "runtime_version": { "type": "string", "maxLength": 64 },
    "model_name": { "type": "string", "maxLength": 128 },
    "homepage_url": { "type": "string", "format": "uri", "maxLength": 2048 }
  },
  "additionalProperties": false
}
