  "properties": {
    "name": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "version": {
      "default": 1,
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "trigger": {
      "$ref": "#/$defs/TriggerConfig"
    },
    "inputs": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/InputParam"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Inputs"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/StepDefinition"
      },
      "minItems": 1,
      "title": "Steps",
      "type": "array"
    },
    "error_handling": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Handling"
    },
    "budget": {
