{
  "$defs": {
    "BudgetConfig": {
      "properties": {
        "max_llm_cost_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Llm Cost Usd"
        },
        "max_duration_minutes": {
          "anyOf": [
            {
              "maximum": 1440,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Duration Minutes"
        }
      },
      "title": "BudgetConfig",
      "type": "object"
    },
    "GuardConfig": {
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "pii_tokenize": {
          "default": true,
          "title": "Pii Tokenize",
          "type": "boolean"
        }
      },
      "title": "GuardConfig",
      "type": "object"
    },
    "InputParam": {
      "properties": {
        "type": {
          "default": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ],
          "title": "Type",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "required": {
          "default": false,
          "title": "Required",
          "type": "boolean"
        },
        "default": {
          "default": null,
          "title": "Default"
        }
      },
      "title": "InputParam",
      "type": "object"
    },
    "RetryConfig": {
      "properties": {
        "max_attempts": {
          "default": 3,
          "maximum": 10,
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        },
        "backoff": {
          "default": "exponential",
          "enum": [
            "exponential",
            "fixed"
          ],
          "title": "Backoff",
          "type": "string"
        },
        "base_delay": {
          "default": 5,
          "maximum": 300,
          "minimum": 1,
          "title": "Base Delay",
          "type": "integer"
        }
      },
      "title": "RetryConfig",
      "type": "object"
    },
