    "VaultConfig": {
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "visibility": {
          "default": "private",
          "enum": [
            "private",
            "internal"
          ],
          "title": "Visibility",
          "type": "string"
        }
      },
      "title": "VaultConfig",
      "type": "object"
    }
